#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// Endereço padrão do LCD I2C (0x27 ou 0x3F)
LiquidCrystal_I2C lcd(0x27, 16, 2);

// Definição dos pinos
#define SENSOR_BAIXO 2
#define SENSOR_ALTO  3
#define LED_VERMELHO 4
#define LED_VERDE    5
#define BOMBA        6

bool estadoBomba = false;

void setup() {
  pinMode(SENSOR_BAIXO, INPUT_PULLUP);
  pinMode(SENSOR_ALTO, INPUT_PULLUP);
  pinMode(LED_VERMELHO, OUTPUT);
  pinMode(LED_VERDE, OUTPUT);
  pinMode(BOMBA, OUTPUT);

  digitalWrite(BOMBA, LOW);

  lcd.init();
  lcd.backlight();

  lcd.setCursor(0, 0);
  lcd.print("Controle Nivel");
  lcd.setCursor(0, 1);
  lcd.print("Caixa d'Agua");
  delay(2000);
  lcd.clear();
}

void loop() {
  bool nivelBaixo = !digitalRead(SENSOR_BAIXO);
  bool nivelAlto  = !digitalRead(SENSOR_ALTO);

  // Lógica da bomba
  if (nivelBaixo && !nivelAlto) {
    estadoBomba = true;
  }

  if (nivelAlto) {
    estadoBomba = false;
  }

  // Acionamento da bomba
  digitalWrite(BOMBA, estadoBomba);

  // LEDs indicadores
  digitalWrite(LED_VERMELHO, nivelBaixo);
  digitalWrite(LED_VERDE, nivelAlto);

  // Atualização do LCD
  lcd.setCursor(0, 0);
  lcd.print("Bomba: ");
  lcd.print(estadoBomba ? "LIGADA   " : "DESLIGADA");

  lcd.setCursor(0, 1);
  if (nivelAlto) {
    lcd.print("Nivel: ALTO     ");
  } else if (nivelBaixo) {
    lcd.print("Nivel: BAIXO    ");
  } else {
    lcd.print("Nivel: MEDIO    ");
  }

  delay(500);
}
