// C++ code
// Código para máquina de estado
// Transição entre etapas
// Professor Luiz Carlos

int BL = 6;          // Botão START
int STOP = 7;        // Botão STOP (interrupt)

int rele1 = 2;
int rele2 = 3;
int rele3 = 4;
int rele4 = 5;

volatile bool parar = false; // Variável da interrupção

int estado = 0;

void setup()
{
  pinMode(BL, INPUT_PULLUP);
  pinMode(STOP, INPUT_PULLUP);

  pinMode(rele1, OUTPUT);
  pinMode(rele2, OUTPUT);
  pinMode(rele3, OUTPUT);
  pinMode(rele4, OUTPUT);

  // Interrupção no botão STOP
  attachInterrupt(digitalPinToInterrupt(STOP), emergencia, FALLING);
}

void loop()
{
  // Se pressionar STOP
  if (parar == true) {
    estado = 0;

    digitalWrite(rele1, LOW);
    digitalWrite(rele2, LOW);
    digitalWrite(rele3, LOW);
    digitalWrite(rele4, LOW);

    parar = false;
  }

  // BOTÃO START
  if (digitalRead(BL) == LOW && estado == 0) {
    delay(300);
    estado = 1;
  }

  // Etapa 0
  if (estado == 0) {

    digitalWrite(rele1, LOW);
    digitalWrite(rele2, LOW);
    digitalWrite(rele3, LOW);
    digitalWrite(rele4, LOW);
  }

  // Etapa 1
  else if (estado == 1) {

    digitalWrite(rele1, LOW);
    digitalWrite(rele2, LOW);
    digitalWrite(rele3, LOW);
    digitalWrite(rele4, HIGH);

    delay(1000);

    if (!parar) {
      estado = 2;
    }
  }

  // Etapa 2
  else if (estado == 2) {

    digitalWrite(rele1, HIGH);
    digitalWrite(rele2, LOW);
    digitalWrite(rele3, LOW);
    digitalWrite(rele4, HIGH);

    delay(1000);

    if (!parar) {
      estado = 3;
    }
  }
}

// Função da interrupção
void emergencia() {
  parar = true;
}
